{
  "name": "vsc-orca",
  "displayName": "Orca",
  "description": "Receive execution bundles and submit evidence from your IDE",
  "version": "0.1.3",
  "publisher": "raftio",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:orca.bundleTree"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "orca",
          "title": "Orca",
          "icon": "$(symbol-structure)"
        }
      ]
    },
    "views": {
      "orca": [
        {
          "id": "orca.bundleTree",
          "name": "Execution Bundle"
        }
      ]
    },
    "commands": [
      {
        "command": "orca.fetchBundle",
        "title": "Orca: Fetch Bundle",
        "icon": "$(cloud-download)"
      },
      {
        "command": "orca.submitEvidence",
        "title": "Orca: Submit Evidence",
        "icon": "$(beaker)"
      },
      {
        "command": "orca.disconnect",
        "title": "Orca: Disconnect"
      },
      {
        "command": "orca.refreshBundle",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "orca.executeTask",
        "title": "Orca: Execute Task",
        "icon": "$(play)"
      },
      {
        "command": "orca.executeBundle",
        "title": "Orca: Execute Bundle",
        "icon": "$(run-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "orca.executeBundle",
          "when": "view == orca.bundleTree",
          "group": "navigation"
        },
        {
          "command": "orca.fetchBundle",
          "when": "view == orca.bundleTree",
          "group": "navigation"
        },
        {
          "command": "orca.refreshBundle",
          "when": "view == orca.bundleTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "orca.executeBundle",
          "when": "view == orca.bundleTree && viewItem == bundle",
          "group": "inline"
        },
        {
          "command": "orca.executeTask",
          "when": "view == orca.bundleTree && viewItem == task",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Orca",
      "properties": {
        "orca.apiUrl": {
          "type": "string",
          "default": "http://localhost:3001",
          "description": "Base URL of the Orca API"
        },
        "orca.apiToken": {
          "type": "string",
          "default": "",
          "description": "Bearer token for authenticating with the Orca API"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run build -- --watch",
    "package": "npm run build -- --minify",
    "lint": "eslint src --ext .ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0"
  }
}
